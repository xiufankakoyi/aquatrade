# ============================================
# 环境配置文件 (包含敏感信息)
# ============================================
# 注意: .env 文件包含API密钥，不应该上传
# 但是 .env.template 是模板，应该上传
.env
.env.local
.env.*.local
!.env.template

# 敏感配置文件 (包含所有密钥)
config/secrets.py
!config/secrets_template.py

# QuickTiny 爬虫配置 (包含 Token 和密码)
quant/config.json

# ============================================
