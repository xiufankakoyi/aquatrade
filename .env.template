# =============================================================================
# AquaTrade 环境配置模板
# =============================================================================
# 使用方法：
# 1. 复制此文件为 .env: cp .env.template .env
# 2. 修改 .env 文件中的配置值
# 3. 重启应用程序使配置生效
# 
# 【重要】敏感配置（API密钥、Token等）请填写在 config/secrets.py 中
# 首次使用请复制 config/secrets_template.py 为 config/secrets.py
# =============================================================================

# =============================================================================
# 数据库后端配置 (Database Backend Configuration)
# =============================================================================
# 可选值：
# - arcticdb: 推荐！三层架构 (ArcticDB + Arrow + Polars)
#             适用场景：高频数据、大规模回测、实时分析
DB_BACKEND=arcticdb

# 传统数据库存储路径 (使用 duckdb/questdb 时有效)
DB_PATH=data/database/stock_data.db

# =============================================================================
# 【三层架构】ArcticDB 配置 (当 DB_BACKEND=arcticdb 时生效)
# =============================================================================

# ArcticDB 存储路径 (默认: data/arcticdb)
ARCTICDB_PATH=data/arcticdb

# 写入批次大小 (默认: 10000)
# 影响内存使用和写入性能，根据可用内存调整
ARCTICDB_WRITE_BATCH_SIZE=10000

# 压缩类型: lz4(快速) 或 zstd(高压缩比) (默认: lz4)
ARCTICDB_COMPRESSION=lz4

# 是否启用版本控制 (默认: true)
# 启用后可进行数据回溯和审计
ARCTICDB_ENABLE_VERSIONING=true

# =============================================================================
# 【三层架构】Apache Arrow 交互层配置 (当 DB_BACKEND=arcticdb 时生效)
# =============================================================================

# 批处理大小 (默认: 10000)
# 影响内存使用和传输效率
ARROW_BATCH_SIZE=10000

# 是否使用零拷贝传输 (默认: true)
# 推荐启用以获得最佳性能
ARROW_ZERO_COPY=true

# =============================================================================
# 系统基础配置 (System Base)
# =============================================================================

# 是否启用 GPU 加速 (true/false)
USE_GPU=false

# Redis 配置 (用于任务队列和消息通知)
REDIS_URL=redis://localhost:6379/0
REDIS_TASK_QUEUE=aqua_tasks
REDIS_NOTIFICATION_CHANNEL_PREFIX=aqua_notifications

# =============================================================================
# 策略风控阈值 (Strategy Thresholds)
# =============================================================================

# 最小市值 (万元)
MIN_MARKET_CAP=20000

# 最大市值 (万元)
MAX_MARKET_CAP=5000000

# 选股最低价格
MIN_PRICE=5.0

# 初始回测资金
INITIAL_CAPITAL=1000000

# =============================================================================
# 日志配置 (Logging)
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
