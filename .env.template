# --- 核心数据接口 (Core Data APIs) ---
# Tushare 金融数据接口 Token
TUSHARE_TOKEN=your_tushare_token_here

# --- DragonEye 龙虎榜监控模块 ---
# 龙大/龙虎榜数据爬虫登录凭证 (选填，自动登录用)
DRAGON_USERNAME=your_username
DRAGON_PASSWORD=your_password
DRAGON_TOKEN=your_manual_token_optional

# 飞书/钉钉推送 Webhook 地址
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# --- AI & 大模型配置 (LLM Configuration) ---
# LLM 服务地址 (如 LM Studio: http://localhost:1234/v1)
LLM_API_BASE=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL_NAME=qwen2.5-7b

# --- 系统基础配置 (System Base) ---
# 数据库后端类型 (sqlite / duckdb)
DB_BACKEND=duckdb
# 数据库存储路径 (绝对路径或相对路径)
DB_PATH=data/database/stock_data.db
# 是否启用 GPU 加速 (true/false)
USE_GPU=false

# --- 策略风控阈值 (Strategy Thresholds) ---
# 最小市值 (万元)
MIN_MARKET_CAP=20000
# 最大市值 (万元)
MAX_MARKET_CAP=5000000
# 选股最低价格
MIN_PRICE=5.0
# 初始回测资金
INITIAL_CAPITAL=1000000
