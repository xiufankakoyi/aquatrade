# =============================================================================
# AquaTrade Environment Template
# =============================================================================
# Usage:
# 1. Copy this file to .env
# 2. Fill local values such as Tushare token and Redis URL
# 3. Restart the application

# =============================================================================
# Data Backend
# =============================================================================
DB_BACKEND=lancedb
LANCEDB_PATH=data/lancedb

# Optional local database path used by tools that still need a file DB.
DB_PATH=data/database/stock_data.db

# =============================================================================
# Apache Arrow / Polars
# =============================================================================
ARROW_BATCH_SIZE=10000
ARROW_ZERO_COPY=true

# =============================================================================
# System Base
# =============================================================================
USE_GPU=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TASK_QUEUE=aqua_tasks
REDIS_NOTIFICATION_CHANNEL_PREFIX=aqua_notifications

# =============================================================================
# Strategy Thresholds
# =============================================================================
MIN_MARKET_CAP=20000
MAX_MARKET_CAP=5000000
MIN_PRICE=5.0
INITIAL_CAPITAL=1000000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
